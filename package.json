{
  "name": "figma-plugin-react-vite",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "start": "run-s dev",
    "dev": "run-s watch",
    "dev:ui-only": "vite -c ./vite.config.ui.ts",
    "watch": "run-p watch:*",
    "watch:ui": "npm run build:ui -- --watch --mode=development",
    "watch:plugin": "npm run build:plugin -- --watch --mode=development",
    "clean": "rimraf dist/*",
    "types": "run-s types:*",
    "types:src": "tsc",
    "types:node": "tsc -P tsconfig.node.json",
    "build": "run-s build:*",
    "prebuild": "run-s types clean",
    "build:ui": "vite build -c ./vite.config.ui.ts",
    "build:plugin": "vite build -c ./vite.config.plugin.ts"
  },
  "dependencies": {
    "@octokit/core": "^7.0.6",
    "@radix-ui/react-tabs": "^1.1.15",
    "monorepo-networker": "^2.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.129.0",
    "@types/node": "^25.9.3",
    "@types/postcss-url": "^10.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.4.21",
    "postcss-url": "^10.1.3",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vite-plugin-generate-file": "^0.3.1",
    "vite-plugin-react-rich-svg": "^1.3.0",
    "vite-plugin-singlefile": "^2.3.3"
  }
}
