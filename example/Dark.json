{
  "colors": {
    "bg-base": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [0.117647, 0.117647, 0.117647],
        "alpha": 1,
        "hex": "#1E1E1E"
      }
    },
    "bg-surface": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [0.176471, 0.176471, 0.176471],
        "alpha": 1,
        "hex": "#2D2D2D"
      }
    },
    "text-primary": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [0.933333, 0.933333, 0.933333],
        "alpha": 1,
        "hex": "#EEEEEE"
      }
    },
    "text-secondary": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [0.666667, 0.666667, 0.666667],
        "alpha": 1,
        "hex": "#AAAAAA"
      }
    },
    "brand": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [0.219608, 0.713725, 1.0],
        "alpha": 1,
        "hex": "#38B6FF"
      }
    },
    "border": {
      "$type": "color",
      "$value": {
        "colorSpace": "srgb",
        "components": [0.239216, 0.239216, 0.239216],
        "alpha": 1,
        "hex": "#3D3D3D"
      }
    },
    "interactive-active": {
      "$type": "color",
      "$value": "{colors.brand}"
    }
  },
  "dimensions": {
    "spacing-sm": {
      "$type": "dimension",
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "spacing-md": {
      "$type": "dimension",
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "spacing-lg": {
      "$type": "dimension",
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "radius-round": {
      "$type": "dimension",
      "$value": {
        "value": 8,
        "unit": "px"
      }
    }
  },
  "flags": {
    "is-dark-theme": {
      "$type": "number",
      "$value": 1,
      "$extensions": {
        "com.figma.type": "boolean"
      }
    }
  }
}
